{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@warp-dot-dev/opencode-warp"
  ],
  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "http://127.0.0"
        //"timeout":
        //"setCacheKy": (bool)
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B Local",
        },
      }
    }
  },
  /// Options
  // "model": "models to use but this project its using Subagents"
  // "small_model": it does not need this, due to subagents, this is use whe you need small tasks, configurate a small model for this
  // "agent": {
  //   "orchestrator": {
  //     "disabled": (bool)
  //     // randomness of the generated text, if we dont se tup this field, opencode will taje the default LLM Ztemperature 
  //     "temperature": 0,
  //     "mode": "primary",
  //     "model": "opencode/minimax-m2.5-free",
  //     "description": "Agent description",
  //     "prompt": "File or description, to setup the agents behavior",
  //     // determines the number of interactions, tha the agent has, this is the princpial mechanism to save tokens, ist infinity by
  //     "steps": 1,
  //     "permission": {
  //       "task": {
  //         "*": "deny",
  //         "spec-manager": "allow",
  //         "planner": "allow",
  //         "developer": "allow",
  //         "reviewer": "allow",
  //         "researcher": "allow"
  //       }
  //     },
  //     // available agents tools
  //     "tools": {
  //       "write": false,
  //       "edit": false,
  //       "bash": false
  //     }
  //   },
  // }
  
  //subagents configuration
  "default_agent": "orchestrator",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "description": "Main orchestrator that delegates tasks to specialized agents",
      "prompt": "{file:docs/opencode/prompts/orchestrator.md}",
      "steps": 35,
      "permission": {
        "question": "allow",
        "task": {
          "*": "deny",
          "spec-manager": "allow",
          "planner": "allow",
          "developer": "allow",
          "reviewer": "allow",
          "researcher": "allow"
        }
      },
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "spec-manager": {
      "mode": "subagent",
      "model": "nvidia/minimaxai/minimax-m2.7",
      "description": "Executes OpenSpec CLI - explore, propose, verify, archive",
      "prompt": "{file:docs/opencode/prompts/spec-manager.md}",
      "steps": 8,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "planner": {
      "mode": "subagent",
      "model": "opencode/ring-2.6-1t-free",
      "description": "Planning specialist",
      "prompt": "{file:docs/opencode/prompts/planner.md}",
      "steps": 5,
      "tools": {
        "write": true,
        "edit": false,
        "bash": false
      }
    },
    "developer": {
      "mode": "subagent",
      "model": "nvidia/qwen/qwen3-coder-480b-a35b-instruct",
      "description": "Implementation agent",
      "prompt": "{file:docs/opencode/prompts/developer.md}",
      "steps": 15,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode/nemotron-3-super-free",
      "description": "Code reviewer",
      "prompt": "{file:docs/opencode/prompts/reviewer.md}",
      "steps": 5,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "researcher": {
      "mode": "subagent",
      "model": "opencode/minimax-m2.5",
      "description": "Research agent",
      "prompt": "{file:docs/opencode/prompts/researcher.md}",
      "steps": 8,
      "permission": {
        "webfetch": "allow"
      },
      "tools": {
        "bash": false
      }
    }
  }
}